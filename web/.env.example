NEXT_PUBLIC_APP_URL=https://your-app.example.com

# AI chat model
AI_BASE_URL=https://api.openai.com/v1
AI_API_KEY=your-ai-api-key
AI_MODEL=gpt-4.1-mini

# Optional AI provider settings
AI_PROVIDER_NAME=openaiCompatible
AI_SUPPORTS_STRUCTURED_OUTPUTS=false
AI_LESSON_INTAKE_MODEL=
AI_LESSON_INTENT_MODEL=
AI_PATCH_MODEL=
AI_LESSON_PATCH_MODEL=
AI_HTML_PLANNER_MODEL=

# Optional embedding provider settings for vector search / ingestion
# Keep AI_EMBEDDING_DIMENSIONS aligned with your Supabase vector column size.
AI_EMBEDDING_BASE_URL=${AI_BASE_URL}
AI_EMBEDDING_API_KEY=${AI_API_KEY}
AI_EMBEDDING_PROVIDER_NAME=${AI_PROVIDER_NAME}
AI_EMBEDDING_MODEL=nvidia/llama-3.2-nv-embedqa-1b-v2
AI_EMBEDDING_DIMENSIONS=1536

# Fallback for OpenAI-compatible auth if you do not use AI_API_KEY
OPENAI_API_KEY=

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-supabase-publishable-key
SUPABASE_SECRET_KEY=your-supabase-service-role-key

# S3-compatible export / artifact storage
S3_ENDPOINT=https://your-s3-endpoint.example.com
S3_REGION=your-s3-region
S3_ACCESS_KEY_ID=your-s3-access-key-id
S3_SECRET_ACCESS_KEY=your-s3-secret-access-key
S3_USER_AGENT=S3 Browser
S3_BUCKET=your-default-bucket
S3_EXPORT_BUCKET=
S3_ARTIFACT_BUCKET=
S3_WORKSPACE_BUCKET=

# Optional runtime flags
SMARTEDU_ALLOW_ANONYMOUS_AI=false
SMARTEDU_RATE_LIMIT_FALLBACK=memory

# Optional Upstash rate limit backend
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
